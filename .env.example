# ─── Required ────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─── Enrichment (strongly recommended) ───────────────────────────────────────
EXA_API_KEY=...                    # LinkedIn + TripAdvisor enrichment via Exa

# ─── CRM sync (optional) ─────────────────────────────────────────────────────
NOTION_API_KEY=secret_...
NOTION_DATABASE_ID=...

# ─── Daily digest email (optional) ───────────────────────────────────────────
DIGEST_EMAIL_FROM=you@gmail.com    # Gmail sender address
DIGEST_EMAIL_TO=you@gmail.com      # Where to send the daily digest
DIGEST_EMAIL_PASSWORD=xxxx-xxxx    # Gmail app password (not your main password)

# ─── Customization ───────────────────────────────────────────────────────────
COMPANY_NAME=Your Company
COMPANY_CONTEXT=Your product or service description (1-2 sentences)
SALES_REP_NAME=Your Name

# ─── Model selection ─────────────────────────────────────────────────────────
# ANTHROPIC_MODEL=claude-opus-4-6  # Default. Use claude-haiku-4-5-20251001 to reduce cost.

# ─── Demo mode ───────────────────────────────────────────────────────────────
# DEMO_MODE=false                  # Set to true to cap at DEMO_LIMIT analyses (uses Haiku)
# DEMO_LIMIT=3
